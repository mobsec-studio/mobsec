{
  "name": "mobsec-studio",
  "version": "0.1.0-beta.2",
  "description": "Production-grade Android penetration testing platform. Intercept, instrument, and bypass - fully local.",
  "keywords": [
    "android",
    "security",
    "mobile-security",
    "penetration-testing",
    "apk",
    "frida",
    "jadx",
    "adb",
    "electron"
  ],
  "main": "./out/main/index.js",
  "author": {
    "name": "MobSec Studio",
    "email": "hello@mobsec.studio"
  },
  "homepage": "https://mobsec.studio",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm build:agent && electron-vite dev",
    "start": "electron-vite preview",
    "build:agent": "node scripts/build-agent.mjs",
    "build:agent:watch": "node scripts/build-agent.mjs --watch",
    "build": "pnpm build:agent && electron-vite build",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:linux:appimage": "pnpm build && electron-builder --linux AppImage --x64 --arm64",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:agent": "tsc --noEmit -p tsconfig.agent.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web && pnpm typecheck:agent",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-server-node-tcp": "^2.5.2",
    "@yume-chan/scrcpy": "^2.3.0",
    "@yume-chan/scrcpy-decoder-webcodecs": "^2.5.3",
    "@yume-chan/stream-extra": "^2.6.1",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "extract-zip": "^2.0.1",
    "framer-motion": "^11.11.17",
    "frida": "^17.9.10",
    "lucide-react": "^0.460.0",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.4.0",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "winston": "^3.17.0",
    "xz-decompress": "^0.2.3",
    "yauzl": "^3.2.0",
    "zustand": "^5.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "frida"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/frida-gum": "^19.1.0",
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "frida-java-bridge": "^7.0.13",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "rcedit": "5.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
